MONGODB_URI=mongodb://localhost:27017/chatbot_db
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_MODEL=llama3
SECRET_KEY=change-me-to-a-random-secret

# ── Agent configuration (optional overrides) ───────────────────
# How many recent messages to include as context for the LLM
# AGENT_MAX_HISTORY=50
# Maximum tool-call iterations before forcing a final answer
# AGENT_MAX_TOOL_ITERATIONS=5
# Custom system prompt override (advanced — edit system_prompt.md for day-to-day changes)
# AGENT_SYSTEM_PROMPT=...
